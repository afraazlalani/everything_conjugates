{
  "version": 1,
  "name": "design-research-scientist-style-suite",
  "description": "Messy, realistic scientist-style prompts to pressure-test whether the planner stays useful and safe under casual phrasing, shorthand, skepticism, and natural-language construct asks.",
  "schema": {
    "checkObject": {
      "must": "Checks that must pass for the case.",
      "mustNot": "Checks that must stay false or absent for the case."
    },
    "checkFields": [
      "id",
      "bucket",
      "layer",
      "metric",
      "op",
      "value",
      "reason"
    ]
  },
  "cases": [
    {
      "id": "scientist-parkinsons-casual",
      "prompt": "parkinsons conjugates?",
      "category": "short casual disease prompt",
      "checks": {
        "must": [
          {
            "id": "park-casual-recognized",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "casual disease prompts should still resolve to a named disease."
          },
          {
            "id": "park-casual-disease-level",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "disease-level",
            "reason": "a short casual disease prompt should stay disease-level."
          },
          {
            "id": "park-casual-exploration",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationPresent",
            "op": "equals",
            "value": true,
            "reason": "casual disease prompts should still surface useful exploration."
          },
          {
            "id": "park-casual-depth",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "explorationDepthScore",
            "op": "min",
            "value": 4,
            "reason": "the exploration buckets should still be scientifically useful, not generic filler."
          },
          {
            "id": "park-casual-distinct-lanes",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "explorationHasDistinctMechanismLanes",
            "op": "equals",
            "value": true,
            "reason": "messy disease-only prompts should still produce differentiated strategy lanes."
          },
          {
            "id": "park-casual-neuro-lanes",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "explorationNeuroDegenerativeUseful",
            "op": "equals",
            "value": true,
            "reason": "casual neurodegenerative prompts should still surface differentiated cns strategy lanes, not only generic barrier/pathway language."
          },
          {
            "id": "park-casual-exploration-first",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "diseaseOnlyExplorationLeadsOutput",
            "op": "equals",
            "value": true,
            "reason": "the visible answer should lead with useful disease-level exploration, not failure language."
          }
        ],
        "mustNot": [
          {
            "id": "park-casual-no-fake-target",
            "bucket": "recognition",
            "layer": "parser",
            "metric": "targetMentionPresent",
            "op": "equals",
            "value": true,
            "reason": "casual disease prompts should not invent a target."
          }
        ]
      }
    },
    {
      "id": "scientist-psma-shorthand",
      "prompt": "psma prostate cancer conjugate thoughts",
      "category": "target shorthand prompt",
      "checks": {
        "must": [
          {
            "id": "psma-shorthand-target",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "targetCanonicalPresent",
            "op": "equals",
            "value": true,
            "reason": "target shorthand should still normalize to a real target."
          },
          {
            "id": "psma-shorthand-scope",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "target-conditioned",
            "reason": "target shorthand plus disease context should become target-conditioned."
          },
          {
            "id": "psma-shorthand-guidance",
            "bucket": "construct-guidance",
            "layer": "rendering / UI contract",
            "metric": "actionableConstructGuidancePresent",
            "op": "equals",
            "value": true,
            "reason": "messy but target-coherent prompts should still unlock actionable guidance."
          }
        ],
        "mustNot": []
      }
    },
    {
      "id": "scientist-alzheimers-misspelling",
      "prompt": "alzheimers conj ideas",
      "category": "misspelling / informal wording prompt",
      "checks": {
        "must": [
          {
            "id": "alz-misspell-recognized",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "informal misspelled disease wording should still resolve to a named disease."
          },
          {
            "id": "alz-misspell-exploration",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationPresent",
            "op": "equals",
            "value": true,
            "reason": "informal disease prompts should still produce disease-level exploration."
          },
          {
            "id": "alz-misspell-nonblank",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "groundedDiseaseOutputNonBlank",
            "op": "equals",
            "value": true,
            "reason": "grounded disease prompts should not collapse into empty generic language."
          }
        ],
        "mustNot": []
      }
    },
    {
      "id": "scientist-myasthenia-misspelling",
      "prompt": "possible conjugates for myasthania gravis",
      "category": "misspelled disease prompt",
      "checks": {
        "must": [
          {
            "id": "mg-misspell-recognized",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "common misspellings of a named disease should still normalize to the intended disease when the match is clear."
          },
          {
            "id": "mg-misspell-canonical",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "diseaseCanonical",
            "op": "equals",
            "value": "myasthenia gravis",
            "reason": "the normalized disease should resolve to myasthenia gravis, not a different autoimmune disease."
          },
          {
            "id": "mg-misspell-autoimmune",
            "bucket": "abstraction",
            "layer": "normalization",
            "metric": "diseaseArea",
            "op": "equals",
            "value": "autoimmune",
            "reason": "myasthenia gravis should route into autoimmune disease biology rather than an unrelated disease area."
          },
          {
            "id": "mg-misspell-exploration",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationPresent",
            "op": "equals",
            "value": true,
            "reason": "a misspelled disease-only prompt should still enter useful exploration mode once the disease is recognized."
          },
          {
            "id": "mg-ui-top-card",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "uiTopCardPresent",
            "op": "equals",
            "value": true,
            "reason": "the planner response should start with a compact top answer card."
          },
          {
            "id": "mg-ui-strategy-table",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "strategyTablePresent",
            "op": "equals",
            "value": true,
            "reason": "disease-level exploration should show a compact strategy table instead of only prose."
          },
          {
            "id": "mg-ui-ranking-preview",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "rankingPreviewPresent",
            "op": "equals",
            "value": true,
            "reason": "the planner should surface a visible ranking or class-lean section in the main response."
          },
          {
            "id": "mg-ui-innovation",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "innovationSectionPresent",
            "op": "equals",
            "value": true,
            "reason": "innovative strategy ideas should stay visible in the main response flow."
          },
          {
            "id": "mg-ui-debug-collapsed",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "uiDebugCollapsedByDefault",
            "op": "equals",
            "value": true,
            "reason": "debug should remain available but collapsed by default."
          },
          {
            "id": "mg-ui-no-repeated-report-paragraphs",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "repeatedLongParagraphBlocks",
            "op": "max",
            "value": 0,
            "reason": "the visible response should not read like repeated report paragraphs."
          },
          {
            "id": "mg-autoimmune-specific-lanes",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "autoimmuneSpecificLaneCount",
            "op": "min",
            "value": 2,
            "reason": "antibody-mediated autoimmune prompts should surface more specific immune lanes than generic immune modulation."
          },
          {
            "id": "mg-autoimmune-fcrn-or-igg",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "responseMentionsFcRnOrIgGLowering",
            "op": "equals",
            "value": true,
            "reason": "when antibody-mediated autoimmune biology is plausible, the response should keep igg-lowering or fcrn logic visible."
          },
          {
            "id": "mg-autoimmune-complement-or-antigen",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "responseMentionsComplementLogic",
            "op": "equals",
            "value": true,
            "reason": "myasthenia-style antibody-mediated biology should keep complement logic visible when the disease framing supports it."
          }
        ],
        "mustNot": [
          {
            "id": "mg-misspell-no-wrong-disease",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "responseWrongDiseaseMentionPresent",
            "op": "equals",
            "value": true,
            "reason": "the planner should not confidently show a different disease in the visible answer when normalizing a misspelled disease name."
          }
        ]
      }
    },
    {
      "id": "scientist-skeptical-alz-adc",
      "prompt": "is adc dumb for alzheimer's?",
      "category": "skeptical prompt",
      "checks": {
        "must": [
          {
            "id": "alz-adc-skeptical-low-confidence",
            "bucket": "confidence",
            "layer": "confidence / abstention",
            "metric": "winnerConfidenceRank",
            "op": "max",
            "value": 1,
            "reason": "a skeptical disease-level adc prompt in alzheimer's should stay cautious."
          },
          {
            "id": "alz-adc-skeptical-conflict-language",
            "bucket": "conflict",
            "layer": "rendering / UI contract",
            "metric": "conflictLanguagePresent",
            "op": "equals",
            "value": true,
            "reason": "the planner should say plainly why adc-style logic is in tension with the disease biology."
          },
          {
            "id": "alz-adc-skeptical-clarifier",
            "bucket": "conflict",
            "layer": "rendering / UI contract",
            "metric": "anyClarifierPresent",
            "op": "equals",
            "value": true,
            "reason": "a skeptical mismatch prompt should still end with one useful clarifier."
          }
        ],
        "mustNot": [
          {
            "id": "alz-adc-skeptical-no-high-confidence",
            "bucket": "confidence",
            "layer": "confidence / abstention",
            "metric": "winnerConfidenceLevel",
            "op": "equals",
            "value": "high",
            "reason": "the planner should not become highly confident in a skeptical mismatch prompt."
          }
        ]
      }
    },
    {
      "id": "scientist-dmd-exon-natural",
      "prompt": "dmd exon 51 skipping kinda what delivery format would you start with",
      "category": "mechanism hint without clean structure",
      "checks": {
        "must": [
          {
            "id": "dmd-natural-mechanism",
            "bucket": "mechanism",
            "layer": "biological abstraction",
            "metric": "abstractionTherapeuticIntent",
            "op": "equals",
            "value": "gene/rna modulation",
            "reason": "messy exon-skipping prompts should still sharpen into gene/rna modulation."
          },
          {
            "id": "dmd-natural-compartment",
            "bucket": "abstraction",
            "layer": "biological abstraction",
            "metric": "abstractionCompartmentNeed",
            "op": "equals",
            "value": "nuclear",
            "reason": "exon-skipping prompts should still resolve the correct nuclear compartment."
          },
          {
            "id": "dmd-natural-construct-guidance",
            "bucket": "construct-guidance",
            "layer": "rendering / UI contract",
            "metric": "constructDetailTermCount",
            "op": "min",
            "value": 2,
            "reason": "a natural-language construct ask should still unlock sharper format guidance."
          }
        ],
        "mustNot": []
      }
    },
    {
      "id": "scientist-her2-adc-vs-oligo",
      "prompt": "her2 breast cancer adc vs oligo?",
      "category": "disease + target + modality comparison prompt",
      "checks": {
        "must": [
          {
            "id": "her2-vs-oligo-target-conditioned",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "target-conditioned",
            "reason": "messy target+disease comparison prompts should still become target-conditioned."
          },
          {
            "id": "her2-vs-oligo-target-present",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "targetCanonicalPresent",
            "op": "equals",
            "value": true,
            "reason": "the target shorthand should still normalize correctly."
          },
          {
            "id": "her2-vs-oligo-conflict-language",
            "bucket": "conflict",
            "layer": "rendering / UI contract",
            "metric": "conflictLanguagePresent",
            "op": "equals",
            "value": true,
            "reason": "comparing adc against oligo in a HER2 oncology prompt should surface the biology tension clearly."
          }
        ],
        "mustNot": []
      }
    },
    {
      "id": "scientist-soluble-tgfb-sirna",
      "prompt": "does soluble tgf beta with sirna payload make sense in sclerosis",
      "category": "intracellular target confusion prompt",
      "checks": {
        "must": [
          {
            "id": "tgfb-sirna-conflict-language",
            "bucket": "conflict",
            "layer": "rendering / UI contract",
            "metric": "conflictLanguagePresent",
            "op": "equals",
            "value": true,
            "reason": "extracellular soluble-target biology plus siRNA payload logic should be called out as a mismatch."
          },
          {
            "id": "tgfb-sirna-low-confidence",
            "bucket": "confidence",
            "layer": "confidence / abstention",
            "metric": "winnerConfidenceRank",
            "op": "max",
            "value": 1,
            "reason": "intracellular-vs-extracellular confusion should keep winner confidence low."
          }
        ],
        "mustNot": []
      }
    },
    {
      "id": "scientist-egfrviii-natural-construct",
      "prompt": "if you had to start somewhere for egfrviii gbm what format and linker would you try first",
      "category": "construct-seeking prompt with natural language",
      "checks": {
        "must": [
          {
            "id": "egfrviii-natural-disease-clean",
            "bucket": "normalization",
            "layer": "parser",
            "metric": "parserDiseaseMentionPromptShaped",
            "op": "equals",
            "value": false,
            "reason": "the disease mention should not keep the whole prompt-shaped format/linker wording."
          },
          {
            "id": "egfrviii-natural-target-clean",
            "bucket": "normalization",
            "layer": "parser",
            "metric": "parserTargetMentionPromptShaped",
            "op": "equals",
            "value": false,
            "reason": "the target mention should stay a real biomarker mention, not a prompt fragment."
          },
          {
            "id": "egfrviii-natural-target",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "targetCanonicalPresent",
            "op": "equals",
            "value": true,
            "reason": "natural-language egfrviii prompts should still normalize the target."
          },
          {
            "id": "egfrviii-natural-scope",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "target-conditioned",
            "reason": "egfrviii gbm should stay target-conditioned even in casual phrasing."
          },
          {
            "id": "egfrviii-natural-disease",
            "bucket": "normalization",
            "layer": "normalization",
            "metric": "diseaseCanonicalPresent",
            "op": "equals",
            "value": true,
            "reason": "gbm shorthand should still normalize to a real named disease."
          },
          {
            "id": "egfrviii-natural-oncology",
            "bucket": "abstraction",
            "layer": "biological abstraction",
            "metric": "abstractionPathologyType",
            "op": "equals",
            "value": "oncology",
            "reason": "gbm prompts should route into oncology biology rather than chronic non-oncology fallback logic."
          },
          {
            "id": "egfrviii-natural-guidance",
            "bucket": "construct-guidance",
            "layer": "rendering / UI contract",
            "metric": "actionableConstructGuidancePresent",
            "op": "equals",
            "value": true,
            "reason": "natural-language construct asks should still unlock actionable format/linker guidance."
          },
          {
            "id": "egfrviii-natural-detail",
            "bucket": "construct-guidance",
            "layer": "rendering / UI contract",
            "metric": "constructDetailTermCount",
            "op": "min",
            "value": 3,
            "reason": "the response should get more concrete when the user explicitly asks for format/linker direction."
          },
          {
            "id": "egfrviii-natural-cns-constraints",
            "bucket": "construct-guidance",
            "layer": "rendering / UI contract",
            "metric": "cnsOncologyConstructConstraintLanguagePresent",
            "op": "equals",
            "value": true,
            "reason": "cns oncology construct guidance should mention barrier, penetration, heterogeneity, and binder-format tradeoffs."
          }
        ],
        "mustNot": [
          {
            "id": "egfrviii-natural-no-smdc-lead",
            "bucket": "mechanistic gates / scoring",
            "layer": "mechanistic gates / scoring",
            "metric": "topRankingName",
            "op": "equals",
            "value": "smdc",
            "reason": "the planner should not lead with smdc here without affirmative compact-ligand evidence."
          }
        ]
      }
    }
  ]
}
