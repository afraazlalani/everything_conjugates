{
  "version": 2,
  "name": "design-research-initial-benchmark-suite",
  "description": "Initial planner benchmark cases focused on architectural capabilities rather than scripted disease answers.",
  "schema": {
    "checkObject": {
      "must": "Checks that must pass for the case.",
      "mustNot": "Checks that must stay false or absent for the case."
    },
    "checkFields": [
      "id",
      "bucket",
      "layer",
      "metric",
      "op",
      "value",
      "reason"
    ]
  },
  "cases": [
    {
      "id": "named-alzheimers-disease-level",
      "prompt": "possible conjugates for Alzheimers disease",
      "category": "named disease prompt",
      "checks": {
        "must": [
          {
            "id": "alz-named-disease",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "alzheimer's should be recognized as a specific named disease."
          },
          {
            "id": "alz-disease-level-scope",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "disease-level",
            "reason": "this disease-only prompt should stay disease-level."
          },
          {
            "id": "alz-evidence-grounded",
            "bucket": "grounding",
            "layer": "retrieval",
            "metric": "groundingSource",
            "op": "equals",
            "value": "evidence",
            "reason": "alzheimer's should ground from evidence, not fallback."
          },
          {
            "id": "alz-mechanism-family",
            "bucket": "mechanism",
            "layer": "biological abstraction",
            "metric": "inferredMechanismFamily",
            "op": "equals",
            "value": "pathway modulation",
            "reason": "the planner should infer a broad pathway-modulation frame here."
          },
          {
            "id": "alz-cns-theme",
            "bucket": "disease biology",
            "layer": "evidence-builder",
            "metric": "matchedThemes",
            "op": "includes",
            "value": "cns / bbb",
            "reason": "the disease biology should surface cns/barrier context."
          },
          {
            "id": "alz-neurodegeneration-theme",
            "bucket": "disease biology",
            "layer": "evidence-builder",
            "metric": "matchedThemes",
            "op": "includes",
            "value": "neurodegeneration",
            "reason": "the disease biology should surface neurodegeneration context."
          },
          {
            "id": "alz-abstain",
            "bucket": "abstention",
            "layer": "confidence / abstention",
            "metric": "abstain",
            "op": "equals",
            "value": true,
            "reason": "a disease-level prompt without target/entry handle should still abstain from a hard winner."
          }
        ],
        "mustNot": [
          {
            "id": "alz-no-fake-target",
            "bucket": "recognition",
            "layer": "parser",
            "metric": "targetMentionPresent",
            "op": "equals",
            "value": true,
            "reason": "the planner should not fabricate a target from a disease-only prompt."
          },
          {
            "id": "alz-no-generic-template",
            "bucket": "abstention",
            "layer": "confidence / abstention",
            "metric": "genericAbstentionTemplateUsed",
            "op": "equals",
            "value": true,
            "reason": "the response should not fall back to the generic abstention template."
          }
        ]
      }
    },
    {
      "id": "named-parkinsons-disease-level",
      "prompt": "possible conjugates for Parkinson's disease",
      "category": "named disease prompt",
      "checks": {
        "must": [
          {
            "id": "pd-named-disease",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "parkinson's aliases should normalize to a named disease."
          },
          {
            "id": "pd-specificity",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "diseaseSpecificity",
            "op": "equals",
            "value": "specific",
            "reason": "parkinson's should be treated as a specific named disease."
          },
          {
            "id": "pd-retrieval-starts",
            "bucket": "retrieval",
            "layer": "retrieval",
            "metric": "diseaseBiologyQueryCount",
            "op": "min",
            "value": 1,
            "reason": "named disease recognition should trigger disease-biology retrieval."
          },
          {
            "id": "pd-abstraction-populated",
            "bucket": "abstraction",
            "layer": "biological abstraction",
            "metric": "abstractionSource",
            "op": "notEquals",
            "value": "fallback",
            "reason": "the abstraction block should be populated from evidence or normalized context, not pure fallback."
          },
          {
            "id": "pd-neuro-lanes-useful",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "explorationNeuroDegenerativeUseful",
            "op": "equals",
            "value": true,
            "reason": "neurodegenerative disease-only prompts should preserve differentiated cns strategy lanes, not only generic barrier/pathway language."
          },
          {
            "id": "pd-strategy-card-present",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "presentationStrategyDirectionCardPresent",
            "op": "equals",
            "value": true,
            "reason": "disease-only prompts should shape a clear best-current-strategy-direction card instead of opening with blank abstention."
          },
          {
            "id": "pd-section-order-valid",
            "bucket": "ui contract",
            "layer": "rendering / UI contract",
            "metric": "presentationSectionOrderValid",
            "op": "equals",
            "value": true,
            "reason": "the response should expose the simplified top-to-bottom section order for the redesigned page."
          }
        ],
        "mustNot": [
          {
            "id": "pd-no-fake-target",
            "bucket": "recognition",
            "layer": "parser",
            "metric": "targetMentionPresent",
            "op": "equals",
            "value": true,
            "reason": "the prompt should not be treated as target-conditioned."
          }
        ]
      }
    },
    {
      "id": "named-fshd-disease-level",
      "prompt": "possible conjugates for Facioscapulohumeral muscular dystrophy",
