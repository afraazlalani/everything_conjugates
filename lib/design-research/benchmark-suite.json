          },
          {
            "id": "dm1-no-adc-winner",
            "bucket": "ranking",
            "layer": "mechanistic gates / scoring",
            "metric": "topRankingName",
            "op": "equals",
            "value": "adc",
            "reason": "dm1 should not drift into adc-first reasoning."
          }
        ]
      }
    },
    {
      "id": "broad-muscular-dystrophy-family",
      "prompt": "conjugates for muscular dystrophy",
