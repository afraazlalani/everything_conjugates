{
  "version": 1,
  "name": "design-research-transfer-benchmark-suite",
  "description": "Harder transfer cases with unseen diseases, aliases, and wording variation to pressure-test generalization.",
  "schema": {
    "checkObject": {
      "must": "Checks that must pass for the case.",
      "mustNot": "Checks that must stay false or absent for the case."
    },
    "checkFields": [
      "id",
      "bucket",
      "layer",
      "metric",
      "op",
      "value",
      "reason"
    ]
  },
  "cases": [
    {
      "id": "transfer-named-huntington-disease",
      "prompt": "possible conjugates for Huntington's disease",
      "category": "named disease prompt",
      "checks": {
        "must": [
          {
            "id": "hd-named-disease",
            "bucket": "recognition",
            "layer": "normalization",
            "metric": "namedDiseaseRecognized",
            "op": "equals",
            "value": true,
            "reason": "huntington's disease should be recognized as a specific named disease."
          },
          {
            "id": "hd-disease-level",
            "bucket": "scope",
            "layer": "normalization",
            "metric": "recommendationScope",
            "op": "equals",
            "value": "disease-level",
            "reason": "a disease-only neurodegeneration prompt should stay disease-level."
          },
          {
            "id": "hd-pathway-like-mechanism",
            "bucket": "mechanism",
            "layer": "biological abstraction",
            "metric": "abstractionTherapeuticIntent",
            "op": "oneOf",
            "value": [
              "pathway modulation",
              "gene/rna modulation"
            ],
            "reason": "the planner should map neurodegeneration into non-cytotoxic disease biology rather than payload-kill logic."
          },
          {
            "id": "hd-cytotoxic-discouraged",
            "bucket": "fit",
            "layer": "biological abstraction",
            "metric": "abstractionCytotoxicFit",
            "op": "equals",
            "value": "discouraged",
            "reason": "cytotoxic logic should be discouraged for chronic neurodegeneration."
          },
          {
            "id": "hd-exploration-present",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationPresent",
            "op": "equals",
            "value": true,
            "reason": "grounded disease-only prompts should surface an exploration object."
          },
          {
            "id": "hd-exploration-buckets",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationBucketCount",
            "op": "min",
            "value": 1,
            "reason": "disease-only exploration should show at least one plausible strategy bucket."
          },
          {
            "id": "hd-exploration-constraints",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationDominantConstraintCount",
            "op": "min",
            "value": 1,
            "reason": "disease-only exploration should show dominant constraints."
          },
          {
            "id": "hd-exploration-clarifier",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "explorationClarifierPresent",
            "op": "equals",
            "value": true,
            "reason": "disease-only exploration should surface one most useful clarifier."
          },
          {
            "id": "hd-bucket-modality-mapping",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "bucketHasModalityMapping",
            "op": "equals",
            "value": true,
            "reason": "each disease-only strategy bucket should map to plausible modality families."
          },
          {
            "id": "hd-bucket-entry-handle",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "bucketHasEntryHandleLogic",
            "op": "equals",
            "value": true,
            "reason": "each disease-only strategy bucket should explain what kind of entry handle or transport logic would make it viable."
          },
          {
            "id": "hd-bucket-assumptions",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "bucketHasRequiredAssumptions",
            "op": "equals",
            "value": true,
            "reason": "each disease-only strategy bucket should include required assumptions."
          },
          {
            "id": "hd-bucket-failure-mode",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "bucketHasFailureMode",
            "op": "equals",
            "value": true,
            "reason": "each disease-only strategy bucket should include a failure mode."
          },
          {
            "id": "hd-bucket-disease-specificity",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "bucketHasDiseaseSpecificConstraintLanguage",
            "op": "equals",
            "value": true,
            "reason": "disease-only strategy buckets should reflect disease-specific abstraction constraints."
          },
          {
            "id": "hd-bucket-depth",
            "bucket": "exploration-quality",
            "layer": "exploration synthesis",
            "metric": "explorationDepthScore",
            "op": "min",
            "value": 4,
            "reason": "generic non-empty buckets should not pass as useful exploration."
          },
          {
            "id": "hd-grounded-output-nonblank",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "groundedDiseaseOutputNonBlank",
            "op": "equals",
            "value": true,
            "reason": "grounded disease-level prompts should not collapse into blank generic output."
          }
        ],
        "mustNot": [
          {
            "id": "hd-no-fake-target",
            "bucket": "recognition",
            "layer": "parser",
            "metric": "targetMentionPresent",
            "op": "equals",
            "value": true,
            "reason": "the disease-only prompt should not invent a target."
          },
          {
            "id": "hd-no-winner-leak",
            "bucket": "exploration",
            "layer": "rendering / UI contract",
            "metric": "winnerLikeOutputWithLowWinnerConfidence",
            "op": "equals",
            "value": true,
            "reason": "low-winner-confidence exploration states should not leak winner-style output."
          }
        ]
      }
    },
